{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/agent_status.sh\" codex idle" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/agent_status.sh\" codex working" }] }
    ],
    "PermissionRequest": [
      { "hooks": [{ "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/agent_status.sh\" codex waiting" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "\"${PLUGIN_ROOT}/hooks/agent_status.sh\" codex done" }] }
    ]
  }
}
